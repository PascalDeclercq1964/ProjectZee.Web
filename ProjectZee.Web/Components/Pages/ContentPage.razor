@page "/content/{id}"
@using ProjectZee.Web.Services
@inject CmsService Cms
<div class="container my-5">

    @if (contentItemProperties == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-info" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        @((MarkupString)contentItemProperties.Content.Markup)
    }
</div>

@code {
    [Parameter]
    public string Id { get; set; }

    CmsContentItem? contentItemProperties;

    protected override async Task OnInitializedAsync()
    {
        contentItemProperties = await Cms.GetPageAsync(Id);
        if (contentItemProperties == null)
            contentItemProperties = new CmsContentItem { Content = new ContentField { Markup = "Oops, foutje ... content niet gevonden." } };
    }

}
