@page "/kandidaat/{id}"
@using Microsoft.AspNetCore.Authorization
@using ProjectZee.Web.Data
@inject ApplicationDbContext Context
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

@attribute [Authorize]
<div class="container my-5">
    <!-- Registratie Formulier Card -->
    <div class="card border-0 shadow bg-white p-4 mt-4">
        <h3 class="fw-bold mb-3 text-dark border-bottom pb-2">
            <i class="bi bi-pencil-square text-success me-2"></i>Kandidaat Registratie
        </h3>
        <p class="text-muted small mb-4">
            Stel jezelf kandidaat.
            Je gegevens zijn na je registratie nog voor niemand zichtbaar. Andere kandidaten voor dit project kunnen je gegevens pas zien nadat je daar uitdrukkelijk toestemming voor hebt gegegeven. Tot zolang zal een andere kandidaat enkel jullie initialen zien.
        </p>

        <EditForm Model="@applicationUser" OnValidSubmit="HandleRegistration">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger small mb-3" />

            <!-- 1. Hoofdkandidaat -->
            <h5 class="fw-bold text-muted mb-3">1. Persoonlijke Gegevens</h5>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Voornaam</label>
                    <InputText @bind-Value="applicationUser.FirstName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Naam</label>
                    <InputText @bind-Value="applicationUser.LastName" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-semibold">Geboortedatum</label>
                <InputDate @bind-Value="applicationUser.BirthDate" class="form-control" />
            </div>

            <div class="mb-4">
                <label class="form-label small fw-semibold">Adres & huisnummer</label>
                <InputText @bind-Value="applicationUser.Address" class="form-control" />
            </div>
            <div class="row g-3 mb-3">
                <div class="mb-4 col-4">
                    <label class="form-label small fw-semibold">Postkode</label>
                    <InputText @bind-Value="applicationUser.PostalCode" class="form-control" />
                </div>
                <div class="mb-4 col-8">
                    <label class="form-label small fw-semibold">Gemeente</label>
                    <InputText @bind-Value="applicationUser.City" class="form-control" />
                </div>
            </div>
            <!-- 2. Optionele Partner / Mede-eigenaar -->
            <div class="form-check form-switch mb-3 bg-light p-3 rounded border">
                <input class="form-check-input ms-0 me-2" type="checkbox" id="hasPartner" @bind="applicationUser.HasPartner">
                <label class="form-check-label fw-bold text-dark" for="hasPartner">Partner of mede-investeerder toevoegen?</label>
            </div>

            @if (applicationUser.HasPartner)
            {
                <div class="p-3 border rounded bg-light mb-4 animated fadeIn">
                    <h6 class="fw-bold text-muted mb-3"><i class="bi bi-person-plus me-1"></i>Gegevens Partner / Mede-eigenaar</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label small">Voornaam partner</label>
                            <InputText @bind-Value="applicationUser.PartnerFirstName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Naam partner</label>
                            <InputText @bind-Value="applicationUser.PartnerLastName" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Geboortedatum partner</label>
                        <InputDate @bind-Value="applicationUser.PartnerBirthDate" class="form-control" />
                    </div>
                </div>
            }

            <!-- 3. Vastgoed Wensen & Budget -->
            <h5 class="fw-bold text-muted mb-3 border-top pt-3">2. Investeringsprofiel & Wensen</h5>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Beoogd Budget (€)</label>
                    <InputNumber @bind-Value="applicationUser.TargetBudget" class="form-control" />
                    <span class="text-muted xsmall">Richtlijn voor jouw aande(e)l(en)</span>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Absoluut Max. Budget (€)</label>
                    <InputNumber @bind-Value="applicationUser.MaxBudget" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-semibold">Gewenste Regio / Gemeente</label>
                <InputText @bind-Value="applicationUser.PreferredRegion" class="form-control" />
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Gewenst aantal slaapkamers</label>
                    <InputNumber @bind-Value="applicationUser.PreferredBedrooms" class="form-control" min="1" max="5" />
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Max. afstand tot strand (meters)</label>
                    <InputNumber @bind-Value="applicationUser.MaxDistanceToBeach" class="form-control" step="50" />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-semibold">Zeezicht vereist?</label>
                <InputSelect @bind-Value="applicationUser.SeaViewPreference" class="form-select">
                    @foreach (var preference in Enum.GetValues<RequirementTypes>())
                    {
                        <option value="@preference">@preference.ToString()</option>
                    }
                </InputSelect>
            </div>

            <!-- 4. Bio / Voorstelling -->
            <h5 class="fw-bold text-muted mb-3 border-top pt-3">3. Wie ben je?</h5>
            <div class="mb-4">
                <label class="form-label small fw-semibold">Korte introductie (Bio)</label>
                <InputTextArea @bind-Value="applicationUser.Bio" class="form-control" rows="4"
                               placeholder="Vertel je toekomstige mede-eigenaars kort wie je bent, je gezinssituatie en waarom je graag wilt deelnemen aan dit project..." />
                <span class="text-muted xsmall">Belangrijk voor de sociale controle en gunning binnen de groep.</span>
            </div>

            <h5 class="fw-bold text-muted mb-3 border-top pt-3">4. Hoeveel aandelen wil je in dit project?</h5>
            <div class="mb-4">
                ...
            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-success btn-lg w-100 fw-bold shadow-sm py-3">
                <i class="bi bi-check-circle-fill me-2"></i>Verstuur mijn kandidatuur
            </button>
        </EditForm>
    </div>
</div>
@code {

    [Parameter]
    public string id { get; set; }

    private ApplicationUser applicationUser { get; set; } = new();


    protected override async Task OnParametersSetAsync()
    {
        // currentProject = Context.Projects
        //     .Include(p => p.ProjectFollowers)
        //     .Include(p => p.ProjectShareholders)
        //     .FirstOrDefault(p => p.ProjectId.ToString() == id);

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity.IsAuthenticated)
        {
            var userName = user.Identity.Name;
            // Hier kun je verdere logica toevoegen om de projecten op te halen die de gebruiker volgt of waarvoor hij kandidaat is.

            applicationUser = Context.Users
                .FirstOrDefault(u => u.UserName == userName);
        }
    }



    private void HandleRegistration()
    {
        ProjectShareholder projectShareholder= new ProjectShareholder
        {
            UserId = applicationUser.Id,
            ProjectId = int.Parse(id),
            ShareCount = 1 // Hier kun je logica toevoegen om het aantal aandelen te bepalen op basis van het opgegeven budget of andere criteria
        };

        //applicationUser.

        Context.SaveChanges();
        Navigation.NavigateTo("/Content/CandidateNextStep");
    }
}
