@page "/projecten"
@using Microsoft.EntityFrameworkCore
@using ProjectZee.Web.Data
@inject ApplicationDbContext Context
@inject NavigationManager NavigationManager
@inject UserState UserState

<div class="container my-5">
    <div class="d-flex justify-content-between">

    <h1 class="mb-4 fw-bold text-dark"><i class="bi bi-building-gear text-info me-2"></i>Lopende Kustprojecten</h1>
    <button class="btn btn-outline-info fw-bold mb-4" @onclick='()=>NavigationManager.NavigateTo("/projectvoorstel")'>Stel nieuw project voor</button>
    </div>
    ---@UserState.Email+++@UserState.Username---
    <div class="row g-4">
        <!-- Linker Kolom: Filters -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm sticky-lg-top" style="top: 90px;">
                <div class="card-body">
                    <h5 class="fw-bold mb-3 border-bottom pb-2"><i class="bi bi-funnel me-2 text-info"></i>Filters</h5>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Regio</label>
                        <select class="form-select bg-light" @bind="filter.Region">
                            <option>Alle regio's</option>
                            <option>Middenkust (Oostende/Nieuwpoort)</option>
                            <option>Oostkust (Knokke/Blankenberge)</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Slaapkamers</label>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="bed2" @bind-value="filter.Bedrooms1">
                            <label class="form-check-label" href="#bed2">1 Slaapkamer</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="bed2" @bind-value="filter.Bedrooms2">
                            <label class="form-check-label" href="#bed2">2 Slaapkamers</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="bed3" @bind-value="filter.Bedrooms3">
                            <label class="form-check-label" href="#bed3">3+ Slaapkamers</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Budget (Max)</label>
                        <input type="range" class="form-range" min="300000" max="800000" step="50000" @bind-value="filter.MaxBudget">
                        <div class="d-flex justify-content-between text-muted small">
                            <span>€300k</span>
                            <span>€800k</span>
                        </div>
                    </div>

                    <button class="btn btn-info w-100 text-white fw-bold">Filters toepassen</button>
                </div>
            </div>
            <div class="card border-0 shadow-sm sticky-lg-top mt-5" style="top: 90px;">
                <div class="card-body">
                </div>
            </div>
        </div>

        <!-- Rechter Kolom: Projecten Lijst -->
        <div class="col-lg-9">
            <div class="row g-4">

                @foreach(var project in filteredprojects)
                {
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm overflow-hidden">
                            <img src="@project.ImageUrl" class="card-img-top" alt="Project @project.Name" style="object-fit:cover; object-position:center;aspect-ratio:1.5;">
                        <div class="card-body">
                            <span class="badge bg-warning text-dark mb-2">@project.StatusDisplay</span>
                            <h4 class="card-title fw-bold text-dark">Project @project.Name</h4>
                            <p class="text-muted mb-3"><i class="bi bi-geo-alt-fill text-danger"></i>@project.RegionOrCity</p>

                            <div class="row g-2 mb-3 bg-light p-2 rounded text-center small">
                                <div class="col-6 border-end"><strong>Budget:</strong> <br><span class="text-info fw-bold">@project.TargetBudget.ToString("C0")</span></div>
                                <div class="col-6"><strong>Kamers:</strong> <br>@project.Bedrooms Slaapkamers</div>
                            </div>

                            <div class="d-flex justify-content-between text-muted small mb-4 px-1">
                                <span><i class="bi bi-eye-fill me-1"></i> @project.ProjectFollowers.Count Volgers</span>
                                <span><i class="bi bi-people-fill me-1"></i> @project.ProjectShareholders.Count / 16 Aandelen</span>
                            </div>

                            <a href="/projectdetail/@project.ProjectId" class="btn btn-outline-secondary w-100 fw-bold">Details</a>
                        </div>
                    </div>
                </div>

                }
            </div>
        </div>
    </div>
</div>

@code {

    List<Project> projects = new List<Project>();
    List<Project> filteredprojects = new List<Project>();
    
    ProjectFilter filter = new ProjectFilter {Bedrooms2=true, MaxBudget=500000};

    override protected void OnInitialized()
    {
        projects=Context.Projects
            .Include(p => p.ProjectFollowers)
            .Include(p => p.ProjectShareholders)
            .Where(p=>p.ProjectState ==ProjectStates.Active)
            .ToList();
        doFilter();
    }

    void doFilter()
    {
        filteredprojects=projects;
    }
    public class ProjectFilter
    {
        public double? MaxBudget { get; set; }
        public bool Bedrooms1 { get; set; }
        public bool Bedrooms2 { get; set; }
        public bool Bedrooms3 { get; set; }
        public string Region { get; set; }
    }
}
