@page "/"

<!-- Hero Section -->

<header class="hero-section text-center">
    <div class="container">
        <h1 class="display-3 fw-bold mb-3"><CmsSnippet Slug="hero-title"/></h1>
        <p class="lead mb-4"><CmsSnippet Slug="hero-subtitle"/></p>
        <a href="/projecten" class="btn btn-info btn-lg fw-bold text-white px-5 shadow">Ontdek Projecten</a>
    </div>
</header>

<!-- Features -->
<section class="container my-5 py-4">
    <div class="row text-center g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <div class="card-body">
                    <i class="bi bi-pie-chart-fill text-info display-4 mb-3"></i>
                    <h3 class="h5 fw-bold">Eerlijke Verdeling</h3>
                    <p class="text-muted">Ons slimme punten- en rotatiesysteem zorgt ervoor dat elke investeerder a rato van zijn aandeel recht heeft op de absolute topweken.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <div class="card-body">
                    <i class="bi bi-shield-check text-info display-4 mb-3"></i>
                    <h3 class="h5 fw-bold">Volledig Transparant</h3>
                    <p class="text-muted">Beheer via een professionele structuur (Odoo). Inzicht in alle vaste lasten, syndicusfacturen en het reservefonds.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <div class="card-body">
                    <i class="bi bi-key-fill text-info display-4 mb-3"></i>
                    <h3 class="h5 fw-bold">Zorgeloos Genieten</h3>
                    <p class="text-muted">Geen gedoe met sleutels of schoonmaak. Alles wordt professioneel gecoördineerd en geregeld voor jouw aankomst.</p>
                </div>
            </div>
        </div>
    </div>
</section>

